VITE_API_BASE_URL=http://localhost:8081
VITE_DEFAULT_SOURCE_LANG=hu
VITE_DEFAULT_TARGET_LANG=en
VITE_SOURCE_NAME=vocab-app
# When true, any input containing a space is treated as a phrase:
# root word and part of speech are hidden, and the result is saved via POST /phrases.
VITE_SPACE_INDICATES_PHRASE=true
